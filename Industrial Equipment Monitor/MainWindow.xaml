<Window x:Class="Industrial_Equipment_Monitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Industrial_Equipment_Monitor"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 장비 등록 -->

        <StackPanel Grid.Row="0"  Orientation="Horizontal" Margin="0 0 0 10">

            <TextBlock Text="DeviceID" Margin="5"/>
            <TextBox Name ="txtDeviceId" Width="120"/>

            <TextBlock Text="Location" Margin="10 5"/>
            <TextBox Name="txtLocation" Width="120"/>

            <Button Content="Add Device" Click="AddDevice_Click" Margin="10 0"/> 
            
        </StackPanel>
        
        <!-- 장비 목록 -->

        <DataGrid Name="dataGridDevices" 
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  SelectionChanged="dataGridDevices_SelectionChanged">
            <DataGrid.Columns>

                <DataGridTextColumn Header="ID" Binding="{Binding DeviceId}" />

                <DataGridTextColumn Header="Location" Binding="{Binding Location}" />

                <DataGridTextColumn Header="Temp (°C)" Binding="{Binding Temperature}" />

                <DataGridTextColumn Header="Status" Binding="{Binding Status}" />

                <DataGridTemplateColumn Header="Indicator">
                    <DataGridTemplateColumn.CellTemplate>

                        <DataTemplate>
                            <Rectangle Width="20"
                                   Height="20"
                                   Fill="{Binding StatusColor}"/>
                        </DataTemplate>

                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        
        <!-- 제어버튼 -->
        
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="10">

            <Button Content="Start"
                    Width="80"
                    Click="Start_Click"
                    Margin="5"/>

            <Button Content="Stop"
                    Width="80"
                    Click="Stop_Click"
                    Margin="5"/>

            <Button Content="Delete"
                    Width="80"
                    Click="Delete_Click"
                    Margin="5"/>
            
            <Button Content="Update"
                    Width="80"
                    Click="Update_Click"
                    Margin="5"/>

        </StackPanel>
        
                          
    </Grid>
</Window>
